# ---- Supabase (auth + database) ----
# Create a project at https://supabase.com, then Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=
# Google OAuth is configured INSIDE Supabase (Authentication → Providers → Google).
# Add your site URL + /auth/callback to Supabase redirect URLs.

# ---- AI coach: Vertex AI Gemini ----
GOOGLE_CLOUD_PROJECT=testing-projects-497315
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
# On Vercel: service-account JSON, or Workload Identity Federation
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ---- Private app: comma-separated emails allowed to sign in.
# Empty = any signed-in Google account (still requires sign-in). ----
ALLOWED_EMAILS=you@example.com

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
